# botkit hello demo — copy to cmd/hello/.env and fill in.

# The WhatsApp number the bot links onto (companion device). Local or
# international form both work, e.g. 0546260906 or +972546260906.
BOT_PHONE=

# Bearer token guarding the pairing ops API. Pick any long random string.
# Every /pair, /status, /groups request must send: Authorization: Bearer <this>
PAIR_TOKEN=

# Where the durable session lives. Survives restarts; delete to force re-pair.
SESSION_DB=whatsapp_session.db

# Ops API listen address. Keep it PRIVATE — never expose this port publicly.
OPS_ADDR=:8080

# Optional: ship structured logs to an OTLP endpoint. Unset = stderr only.
# OTEL_EXPORTER_OTLP_ENDPOINT=
